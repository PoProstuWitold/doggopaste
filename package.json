{
	"name": "doggopaste",
	"description": "Drop your code, let Doggo fetch it! Combination of a Pastebin and CodeShare. Free and selfhostable ",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"start": "turbo run start",
		"check-types": "turbo run check-types",
		"check": "biome check .",
		"check:fix": "biome check . --write"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.1.1",
		"turbo": "^2.5.4",
		"typescript": "^5.8.3"
	},
	"packageManager": "pnpm@10.13.1",
	"engines": {
		"node": ">=22"
	},
	"volta": {
		"node": "22.15.0"
	}
}
