{
	"name": "doggopaste",
	"version": "0.5.0",
	"private": true,
	"description": "Drop your code, let Doggo fetch it! Combination of a Pastebin and CodeShare. Free and selfhostable.",
	"license": "MIT",
	"contributors": [
		{
			"name": "Witold Zawada",
			"url": "https://github.com/PoProstuWitold"
		},
		{
			"name": "Wiktor Wypyszyński",
			"url": "https://github.com/Netr0n07"
		}
	],
	"homepage": "https://github.com/PoProstuWitold/doggopaste",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PoProstuWitold/doggopaste.git"
	},
	"bugs": {
		"url": "https://github.com/PoProstuWitold/doggopaste/issues"
	},
	"keywords": [
		"pastebin",
		"codeshare",
		"code-sharing",
		"collaboration",
		"realtime",
		"self-hosted",
		"monorepo",
		"typescript"
	],
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"start": "turbo run start",
		"check-types": "turbo run check-types",
		"check": "biome check .",
		"check:fix": "biome check . --write"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"turbo": "^2.9.6",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=24",
		"pnpm": ">=10"
	},
	"packageManager": "pnpm@10.33.2",
	"volta": {
		"node": "24.15.0",
		"pnpm": "10.33.2"
	}
}
