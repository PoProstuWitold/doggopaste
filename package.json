{
	"name": "doggopaste",
	"description": "Drop your code, let Doggo fetch it!",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"start": "turbo run start",
		"check-types": "turbo run check-types",
		"check": "biome check .",
		"check:fix": "biome check . --write"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"turbo": "^2.4.4",
		"typescript": "5.8.2"
	},
	"packageManager": "pnpm@10.6.5",
	"engines": {
		"node": ">=22"
	},
	"volta": {
		"node": "22.14.0"
	}
}
