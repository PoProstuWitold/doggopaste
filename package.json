{
	"name": "doggopaste",
	"description": "Drop your code, let Doggo fetch it! Combination of a Pastebin and CodeShare. Free and selfhostable ",
	"version": "0.5.0",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"start": "turbo run start",
		"check-types": "turbo run check-types",
		"check": "biome check .",
		"check:fix": "biome check . --write"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"turbo": "^2.8.20",
		"typescript": "^6.0.2"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22"
	},
	"volta": {
		"node": "24.14.1",
		"pnpm": "10.33.0"
	}
}
