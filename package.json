{
	"name": "doggopaste",
	"description": "Drop your code, let Doggo fetch it! Combination of a Pastebin and CodeShare. Free and selfhostable ",
	"version": "0.5.0",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"start": "turbo run start",
		"check-types": "turbo run check-types",
		"check": "biome check .",
		"check:fix": "biome check . --write"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.3",
		"turbo": "^2.8.10",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@10.30.1",
	"engines": {
		"node": ">=22"
	},
	"volta": {
		"node": "24.13.1",
		"pnpm": "10.30.1"
	}
}
