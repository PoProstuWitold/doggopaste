{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"start": {
			"dependsOn": ["^start"]
		},
		"//#check": {},
		"//#check:fix": {
			"cache": false
		},
		"ncu-u": {
			"dependsOn": ["^ncu-u"]
		},
		"ncu": {
			"dependsOn": ["^ncu"]
		}
	}
}
