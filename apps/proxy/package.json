{
	"name": "proxy",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Proxy for launching web and api on same port",
	"main": "index.js",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"start": "NODE_ENV='production' node --env-file .env build/index.js",
		"dev": "NODE_ENV='development' node --env-file .env --watch --import tsx index.ts",
		"check-types": "tsc --noEmit",
		"ncu-u": "ncu -u && pnpm install",
		"ncu": "ncu"
	},
	"devDependencies": {
		"@types/connect": "^3.4.38",
		"@types/finalhandler": "^1.2.3",
		"@types/node": "^22.15.17",
		"tsx": "^4.19.4"
	},
	"dependencies": {
		"connect": "^3.7.0",
		"finalhandler": "^2.1.0",
		"http-proxy-middleware": "^3.0.5"
	}
}
