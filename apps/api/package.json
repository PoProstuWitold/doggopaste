{
	"name": "api",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "NODE_ENV='development' node --env-file .env --watch --import tsx src/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node --env-file .env build/src/index.js",
		"check-types": "tsc --noEmit",
		"ncu-u": "ncu -u && pnpm install",
		"ncu": "ncu",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "node --env-file .env --import tsx src/db/seed.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.14.1",
		"@hono/zod-validator": "^0.4.3",
		"@scalar/hono-api-reference": "^0.8.1",
		"argon2": "^0.41.1",
		"better-auth": "^1.2.7",
		"drizzle-orm": "^0.42.0",
		"drizzle-seed": "^0.3.1",
		"hono": "^4.7.7",
		"hono-openapi": "^0.4.6",
		"pg": "^8.14.1",
		"random-words": "^2.0.1",
		"socket.io": "^4.8.1",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@types/node": "^22.14.1",
		"@types/pg": "^8.11.13",
		"drizzle-kit": "^0.31.0",
		"rimraf": "^6.0.1",
		"tslib": "^2.8.1",
		"tsx": "^4.19.3",
		"typescript": "^5.8.3"
	}
}
