{
	"name": "api",
	"version": "0.2.0",
	"private": true,
	"type": "module",
	"description": "REST API and WebSockets server for DoggoPaste. Built with Hono and Drizzle ORM",
	"scripts": {
		"dev": "pnpm run db:push && NODE_ENV='development' node --watch --import tsx src/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node build/src/index.js",
		"check-types": "tsc --noEmit",
		"ncu-u": "ncu -u && pnpm install",
		"ncu": "ncu",
		"db:push": "drizzle-kit push --config=drizzle.config.ts",
		"db:generate": "drizzle-kit generate --config=drizzle.config.ts",
		"db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
		"db:seed": "node --env-file .env --import tsx src/db/seed.ts",
		"docs": "pnpx @rcmade/hono-docs generate --config ./hono-docs.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.6",
		"@hono/standard-validator": "^0.1.5",
		"@hono/zod-validator": "^0.7.4",
		"@scalar/hono-api-reference": "^0.9.22",
		"argon2": "^0.44.0",
		"better-auth": "^1.3.34",
		"drizzle-orm": "^0.44.7",
		"drizzle-seed": "^0.3.1",
		"hono": "^4.10.4",
		"hono-openapi": "^1.1.0",
		"pg": "^8.16.3",
		"random-words": "^2.0.1",
		"socket.io": "^4.8.1",
		"zod": "^4.1.12",
		"zod-openapi": "^5.4.3"
	},
	"devDependencies": {
		"@rcmade/hono-docs": "^1.0.30",
		"@types/node": "^24.9.2",
		"@types/pg": "^8.15.6",
		"drizzle-kit": "^0.31.6",
		"rimraf": "^6.1.0",
		"tslib": "^2.8.1",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3"
	}
}
