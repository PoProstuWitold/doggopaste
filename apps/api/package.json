{
	"name": "api",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "NODE_ENV='development' node --env-file .env --watch --import tsx src/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node --env-file .env build/src/index.js",
		"check-types": "tsc --noEmit",
		"ncu-u": "ncu -u && pnpm install",
		"ncu": "ncu",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"@hono/node-server": "^1.14.0",
		"@hono/zod-validator": "^0.4.3",
		"@scalar/hono-api-reference": "^0.7.2",
		"argon2": "^0.41.1",
		"better-auth": "^1.2.4",
		"drizzle-orm": "^0.41.0",
		"hono": "^4.7.5",
		"hono-openapi": "^0.4.6",
		"pg": "^8.14.1",
		"random-words": "^2.0.1",
		"socket.io": "^4.8.1",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@types/node": "^22.13.13",
		"@types/pg": "^8.11.11",
		"drizzle-kit": "^0.30.5",
		"rimraf": "^6.0.1",
		"tslib": "^2.8.1",
		"tsx": "^4.19.3",
		"typescript": "^5.8.2"
	}
}
