{
	"name": "api",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "REST API and WebSocket server for DoggoPaste. Built with Hono and Drizzle ORM",
	"scripts": {
		"dev": "pnpm run db:push && NODE_ENV='development' node --watch --import tsx src/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node build/src/index.js",
		"check-types": "tsc --noEmit",
		"ncu-u": "ncu -u && pnpm install",
		"ncu": "ncu",
		"db:push": "drizzle-kit push --config=drizzle.config.ts",
		"db:generate": "drizzle-kit generate --config=drizzle.config.ts",
		"db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
		"db:seed": "node --env-file .env --import tsx src/db/seed.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.15.0",
		"@hono/zod-validator": "^0.7.0",
		"@scalar/hono-api-reference": "^0.9.10",
		"argon2": "^0.43.0",
		"better-auth": "^1.2.12",
		"drizzle-orm": "^0.44.2",
		"drizzle-seed": "^0.3.1",
		"hono": "^4.8.4",
		"hono-openapi": "^0.4.8",
		"pg": "^8.16.3",
		"random-words": "^2.0.1",
		"socket.io": "^4.8.1",
		"zod": "^4.0.5"
	},
	"devDependencies": {
		"@types/node": "^24.0.13",
		"@types/pg": "^8.15.4",
		"drizzle-kit": "^0.31.4",
		"rimraf": "^6.0.1",
		"tslib": "^2.8.1",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3"
	}
}
